---
import { siteConfig, langMeta, type Lang } from "../config";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = siteConfig.content[lang];
const allLangs = Object.entries(langMeta) as [Lang, { label: string; href: string }][];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center relative">
      <li class="hidden md:block">
        <a
          href="#about"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {content.nav.about}
        </a>
      </li>
      <li class="absolute right-0 flex gap-3">
        {allLangs.map(([key, meta]) => (
          <a
            href={meta.href}
            class={`text-sm font-mono uppercase tracking-widest transition-colors ${
              key === lang
                ? "text-gray-800 font-semibold"
                : "text-gray-400 hover:text-gray-800"
            }`}
            aria-current={key === lang ? "page" : undefined}
          >
            {meta.label}
          </a>
        ))}
      </li>
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
